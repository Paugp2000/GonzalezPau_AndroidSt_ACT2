<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.GonzalezPauAndroidStudioACT2"
        tools:targetApi="31">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <meta-data
                android:name="android.app.lib_name"
                android:value="" />
            <LinearLayout
                xmlns:android="http://schemas.android.com/apk/apk/res/android"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <Button
                    android:id="@+id/btnEx6"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Exercici 6" />

                <Button
                    android:id="@+id/btnEx7"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Exercici 7" />

                <Button
                    android:id="@+id/btnEx8"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Exercici 8" />

                <Button
                    android:id="@+id/btnEx9"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Exercici 9" />

                <Button
                    android:id="@+id/btnEx10"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Exercici 10" />

            </LinearLayout>
        </activity>

    </application>

</manifest>